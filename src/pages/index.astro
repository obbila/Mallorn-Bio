---
import Layout from '~/layouts/PageLayout.astro';
import HeroMallorn from '~/components/widgets/HeroMallorn.astro';
import WhyMallorn from '~/components/widgets/WhyMallorn.astro';
import Vision from '~/components/widgets/Vision.astro';
import OurApproach from '~/components/widgets/OurApproach.astro';
import LivingLab from '~/components/widgets/LivingLab.astro';
import ResearchAreas from '~/components/widgets/ResearchAreas.astro';
import Founders from '~/components/widgets/Founders.astro';
import ContactCTA from '~/components/widgets/ContactCTA.astro';

const metadata = {
  title: 'Understanding Nature. Growing Resilient Food Systems.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <HeroMallorn />
  <WhyMallorn />
  <Vision />
  <OurApproach />
  <LivingLab />
  <ResearchAreas />
  <Founders />
  <ContactCTA />
</Layout>
