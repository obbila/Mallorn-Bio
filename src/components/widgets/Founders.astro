---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
---

<WidgetWrapper id="founders" containerClass="max-w-4xl py-20 text-center md:py-28">
  <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Our people</p>
  <h2 class="mt-5 font-heading text-4xl text-heading sm:text-5xl">
    Built at the intersection of biology, computation and land.
  </h2>
  <p class="mt-6 text-lg leading-relaxed text-muted">
    Mallorn Bio brings together expertise in systems biology, plant biology, synthetic biology, artificial intelligence,
    computational science and regenerative agriculture.
  </p>
</WidgetWrapper>
