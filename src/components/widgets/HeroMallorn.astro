---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';
import heroImage from '~/assets/images/mallorn-farm-hero.png';
---

<section class="relative overflow-hidden bg-secondary text-white">
  <div class="absolute inset-0" aria-hidden="true">
    <Image
      src={heroImage}
      alt=""
      class="h-full w-full object-cover"
      widths={[768, 1280, 2048]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-r from-secondary via-secondary/15 to-secondary/5" aria-hidden="true">
  </div>
  <div class="relative mx-auto max-w-7xl px-4 pb-36 pt-16 sm:px-6 md:pb-52 md:pt-20">
    <div class="max-w-3xl">
      <p class="mb-6 text-sm font-semibold uppercase tracking-[0.18em] text-accent">Mallorn Bio</p>
      <h1 class="font-heading text-5xl leading-[0.95] tracking-tight text-white sm:text-6xl md:text-7xl">
        Understanding Nature.<br />Growing Resilient Food Systems.
      </h1>
      <p class="mt-8 max-w-2xl text-lg leading-relaxed text-white/85 sm:text-xl">
        From molecules to landscapes, we are understanding living systems to build resilient agriculture.
      </p>
      <div class="mt-10">
        <Button variant="primary" text="Explore our approach" href="#approach" class="px-6 py-3" />
      </div>
    </div>
  </div>
</section>
