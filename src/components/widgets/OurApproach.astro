---
import { Icon } from 'astro-icon/components';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';

const areas = [
  [
    'tabler:plant-2',
    'Understanding living soil',
    'Healthy soil is a living ecosystem: diverse, dynamic and fundamental to productive land.',
  ],
  [
    'tabler:network',
    'Understanding whole-farm ecology',
    'Every farm is an interconnected biological system, shaped by its soils, plants, animals and landscape.',
  ],
  [
    'tabler:microscope',
    'Understanding biological processes',
    'Rather than asking what product should be applied, we ask what biological process should be encouraged.',
  ],
  [
    'tabler:tool',
    'Turning understanding into practical tools',
    'Understanding first. Technology second. Our tools emerge from evidence gathered in the real world.',
  ],
];
---

<WidgetWrapper id="approach" containerClass="py-20 md:py-28">
  <div class="max-w-3xl">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Our approach</p><h2
      class="mt-5 font-heading text-4xl text-heading sm:text-5xl"
    >
      Science led by nature.
    </h2><p class="mt-5 text-lg leading-relaxed text-muted">
      We do not begin with a product. We begin by learning how living agricultural systems work.
    </p>
  </div>
  <div class="mt-12 grid gap-px overflow-hidden border border-[#e6e1d5] bg-[#e6e1d5] sm:grid-cols-2">
    {
      areas.map(([icon, title, description]) => (
        <article class="bg-page p-7 md:p-9">
          <>
            <Icon name={icon} class="h-7 w-7 text-accent" />
            <h3 class="mt-5 font-heading text-2xl text-heading">{title}</h3>
            <p class="mt-3 leading-relaxed text-muted">{description}</p>
          </>
        </article>
      ))
    }
  </div>
</WidgetWrapper>
