---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
---

<WidgetWrapper id="vision" containerClass="max-w-none py-20 md:py-28">
  <Fragment slot="bg"><div class="absolute inset-0 bg-[#f7f5ef]"></div></Fragment>
  <div class="mx-auto max-w-4xl text-center">
    <p class="text-sm font-semibold uppercase tracking-[0.18em] text-accent">Our vision</p>
    <h2 class="mt-5 font-heading text-4xl leading-tight text-heading sm:text-5xl">
      A future where every farm understands its biology.
    </h2>
    <p class="mx-auto mt-7 max-w-3xl text-lg leading-relaxed text-muted">
      We are working towards a future in which farmers can measure biological function, ecosystem health and
      resilience—and make decisions informed by the living systems already at work in their fields.
    </p>
  </div>
</WidgetWrapper>
